---
layout: null
permalink: /feed.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title | xml_escape }}</title>
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  <link href="{{ '/feed.xml' | absolute_url }}" rel="self" type="application/atom+xml"/>
  <link href="{{ '/' | absolute_url }}" rel="alternate" type="text/html"/>
  <id>{{ '/' | absolute_url }}</id>
  {% assign sorted_research = site.research | sort: "article_order" | reverse %}
  {% assign latest = sorted_research | first %}
  <updated>{% if latest %}{{ latest.updated | default: latest.created | date_to_xmlschema }}{% else %}{{ site.time | date_to_xmlschema }}{% endif %}</updated>
  <author>
    <name>{{ site.author | default: site.title | xml_escape }}</name>
  </author>
  {% for item in sorted_research %}
  <entry xml:lang="{{ item.language | default: site.lang | default: 'ko' }}">
    <title>{{ item.title | xml_escape }}</title>
    <link href="{{ item.url | absolute_url }}" rel="alternate" type="text/html"/>
    <id>{{ item.url | absolute_url }}</id>
    <updated>{{ item.updated | default: item.created | date_to_xmlschema }}</updated>
    <published>{{ item.created | default: item.updated | date_to_xmlschema }}</published>
    <summary>{{ item.summary | default: item.excerpt | strip_html | normalize_whitespace | xml_escape }}</summary>
  </entry>
  {% endfor %}
</feed>
